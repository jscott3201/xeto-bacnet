pragma: Lib <
  name:    "bacnet.objects.value"
  version: "0.1.0"
  doc:     "BACnet value object types per ASHRAE 135 Clause 12"
>

// Bitstring Value object per Clause 12.39
BitstringValue: Dict {
  objectIdentifier: Number
  objectName: Str
  objectType: Str
  presentValue: Str
  description: Str?
  statusFlags: Str?
  eventState: Str?
  outOfService: Marker?
  bitText: Str?
  bitMask: Str?
  priorityArray: Str?
  relinquishDefault: Str?
  profileName: Str?
}

// Characterstring Value object per Clause 12.40
CharacterstringValue: Dict {
  objectIdentifier: Number
  objectName: Str
  objectType: Str
  presentValue: Str
  description: Str?
  statusFlags: Str?
  eventState: Str?
  outOfService: Marker?
  priorityArray: Str?
  relinquishDefault: Str?
  profileName: Str?
}

