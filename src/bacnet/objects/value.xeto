  objectIdentifier: Number
  objectName: Str
  objectType: Str
  presentValue: Str
  description: Str?
  statusFlags: Str?
  eventState: Str?
  outOfService: Marker?
  isUtc: Marker?
  priorityArray: Str?
  relinquishDefault: Str?
  profileName: Str?
}

