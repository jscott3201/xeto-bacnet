DoorAlarmState: Enum {
  normal
  alarm
  doorOpenTooLong
  forcedOpen
  tamper
  doorFault
  lockFault
  freeAccess
  egressOpen
}

// Door status per Clause 12.26
DoorStatus: Enum {
  closed
  opened
