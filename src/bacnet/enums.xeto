  preparingForBackup
  preparingForRestore
  performingABackup
  performingARestore
}

// Enable/disable per Clause 16.4
EnableDisable: Enum {
  enable
  disable
  disableInitiation
}

// Reinitialized state per Clause 16.5
ReinitializedState: Enum {
  coldstart
  warmstart
  startBackup
  endBackup
  startRestore
  endRestore
  abortRestore
