}

// Engineering units — most common values per Clause 21
// Full list has 290+ entries in ASHRAE 135 Clause 21
EngineeringUnits: Enum {
  // Temperature
  degreesCelsius
  degreesFahrenheit
  degreesKelvin
  degreesKelvinPerHour
  degreesKelvinPerMinute
  degreeDaysCelsius
  degreeDaysFahrenheit
  deltaDegreesFahrenheit
  deltaDegreesKelvin
  // Pressure
  pascals
  hectopascals
  kilopascals
  bars
  millibars
  poundsForcePerSquareInch
  millimetersOfWater
  centimetersOfWater
  inchesOfWater
  millimetersOfMercury
  centimetersOfMercury
  inchesOfMercury
  // Flow
  cubicMetersPerSecond
  cubicMetersPerMinute
  cubicMetersPerHour
  cubicFeetPerSecond
  cubicFeetPerMinute
  cubicFeetPerHour
  litersPerSecond
  litersPerMinute
  litersPerHour
  usGallonsPerMinute
  usGallonsPerHour
  imperialGallonsPerMinute
  // Humidity
  percentRelativeHumidity
  gramsOfWaterPerKilogramDryAir
  // Power / Energy
  milliwatts
  watts
  kilowatts
  megawatts
  btusPerHour
  kiloBtusPerHour
  horsepower
  tonsRefrigeration
  wattHours
  kilowattHours
  megawattHours
  joules
  kilojoules
  megajoules
  btus
  kiloBtus
  megaBtus
  therms
  tonHours
  // Electrical
  milliamperes
  amperes
  volts
  millivolts
  kilovolts
  megavolts
  voltAmperes
  kilovoltAmperes
  megavoltAmperes
  voltAmperesReactive
  kilovoltAmperesReactive
  megavoltAmperesReactive
  ohms
  milliohms
  kilohms
  megohms
  hertz
  kilohertz
  megahertz
  degreesPhase
  powerFactor
  decibels
  decibelsMillivolt
  decibelsVolt
  // Speed
  metersPerSecond
  metersPerMinute
  metersPerHour
  kilometersPerHour
  feetPerSecond
  feetPerMinute
  milesPerHour
  millimetersPerSecond
  millimetersPerMinute
  // Time
  seconds
  hundredthsSeconds
  milliseconds
  minutes
  hours
  days
  weeks
  months
  years
  // Length
  micrometers
  millimeters
  centimeters
  meters
  kilometers
  inches
  feet
  // Area
  squareMeters
  squareCentimeters
  squareFeet
  squareInches
  // Volume
  cubicMeters
  cubicFeet
  liters
  milliliters
  usGallons
  imperialGallons
  // Mass
  milligrams
  grams
  kilograms
  poundsMass
  tons
  // Mass flow
  gramsPerSecond
  gramsPerMinute
  kilogramsPerSecond
  kilogramsPerMinute
  kilogramsPerHour
  poundsMassPerMinute
  poundsMassPerHour
  tonsPerHour
  // Rotation
  revolutionsPerMinute
  // Light
  candelas
  candelasPerSquareMeter
  wattsPerSquareFoot
  wattsPerSquareMeter
  lumens
  luxes
  footCandles
  // Concentration
  partsPerMillion
  partsPerBillion
  percent
  percentPerSecond
  perHour
  perMinute
  perSecond
  // Angular
  degreesAngular
  radians
  radiansPerSecond
  // Misc
  noUnits
}
