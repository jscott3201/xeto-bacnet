LifeSafetyOperation: Enum {
  none
  silence
  silenceAudible
  silenceVisual
  silenceAll
  unsilence
  unsilenceAudible
  unsilenceVisual
  unsilenceAll
  reset
  resetAlarm
  resetFault
}

// Silenced state per Clause 12.15
SilencedState: Enum {
  unsilenced
  audibleSilenced
  visibleSilenced
