}

// Life safety mode per Clause 12.15
LifeSafetyMode: Enum {
  off
  on
  test
  manned
  unmanned
  armed
  disarmed
  prearmed
  slow
  fast
  disconnected
  enabled
  disabled
  automaticReleaseDisabled
  default
}

